<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="four_wheel_mecanum_robot">
  <xacro:property name="pi" value="3.141592653589793"/>

  <!-- Dimensions supplied by user. Units are meters and kilograms. -->
  <xacro:property name="base_length" value="0.35"/>
  <xacro:property name="base_width" value="0.28"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width" value="0.05"/>

  <xacro:property name="base_center_z" value="${wheel_radius + base_height / 2.0}"/>
  <xacro:property name="wheel_x_offset" value="${base_length / 2.0 - wheel_radius}"/>
  <xacro:property name="wheel_y_offset" value="${base_width / 2.0 + wheel_width / 2.0}"/>
  <xacro:property name="wheel_z" value="${wheel_radius}"/>

  <xacro:property name="base_mass" value="6.0"/>
  <xacro:property name="wheel_mass" value="0.35"/>
  <xacro:property name="lidar_mass" value="0.18"/>
  <xacro:property name="lidar_radius" value="0.035"/>
  <xacro:property name="lidar_height" value="0.045"/>
  <xacro:property name="lidar_z" value="${base_center_z + base_height / 2.0 + lidar_height / 2.0}"/>

  <material name="body_blue">
    <color rgba="0.05 0.25 0.70 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>
  <material name="roller_gray">
    <color rgba="0.45 0.48 0.50 1.0"/>
  </material>
  <material name="lidar_black">
    <color rgba="0.03 0.03 0.035 1.0"/>
  </material>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertia
      ixx="${mass * (y * y + z * z) / 12.0}" ixy="0" ixz="0"
      iyy="${mass * (x * x + z * z) / 12.0}" iyz="0"
      izz="${mass * (x * x + y * y) / 12.0}"/>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia_x_axis" params="mass radius length">
    <inertia
      ixx="${0.5 * mass * radius * radius}" ixy="0" ixz="0"
      iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}" iyz="0"
      izz="${mass * (3.0 * radius * radius + length * length) / 12.0}"/>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_center_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_center_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_center_z}" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <xacro:box_inertia mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>
      <ambient>0.05 0.25 0.70 1</ambient>
      <diffuse>0.05 0.25 0.70 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
    </material>
  </gazebo>

  <xacro:macro name="mecanum_wheel" params="prefix x y roller_sign">
    <link name="${prefix}_wheel_link">
      <visual name="tire">
        <origin xyz="0 0 0" rpy="0 ${pi / 2.0} 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <xacro:property name="roller_radius" value="0.008"/>
      <xacro:property name="roller_length" value="${wheel_width * 1.15}"/>
      <visual name="roller_0">
        <origin xyz="0 ${wheel_radius * 0.72} 0" rpy="${roller_sign * pi / 4.0} 0 ${pi / 2.0}"/>
        <geometry><cylinder radius="${roller_radius}" length="${roller_length}"/></geometry>
        <material name="roller_gray"/>
      </visual>
      <visual name="roller_1">
        <origin xyz="0 ${-wheel_radius * 0.72} 0" rpy="${roller_sign * pi / 4.0} 0 ${pi / 2.0}"/>
        <geometry><cylinder radius="${roller_radius}" length="${roller_length}"/></geometry>
        <material name="roller_gray"/>
      </visual>
      <visual name="roller_2">
        <origin xyz="0 0 ${wheel_radius * 0.72}" rpy="${roller_sign * pi / 4.0} 0 ${pi / 2.0}"/>
        <geometry><cylinder radius="${roller_radius}" length="${roller_length}"/></geometry>
        <material name="roller_gray"/>
      </visual>
      <visual name="roller_3">
        <origin xyz="0 0 ${-wheel_radius * 0.72}" rpy="${roller_sign * pi / 4.0} 0 ${pi / 2.0}"/>
        <geometry><cylinder radius="${roller_radius}" length="${roller_length}"/></geometry>
        <material name="roller_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 ${pi / 2.0} 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <xacro:cylinder_inertia_x_axis mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x} ${y} ${wheel_z}" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <dynamics damping="0.05" friction="0.02"/>
    </joint>

    <gazebo reference="${prefix}_wheel_link">
      <material>
        <ambient>0.02 0.02 0.02 1</ambient>
        <diffuse>0.02 0.02 0.02 1</diffuse>
      </material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:mecanum_wheel prefix="front_left" x="${wheel_x_offset}" y="${wheel_y_offset}" roller_sign="1"/>
  <xacro:mecanum_wheel prefix="front_right" x="${wheel_x_offset}" y="${-wheel_y_offset}" roller_sign="-1"/>
  <xacro:mecanum_wheel prefix="rear_left" x="${-wheel_x_offset}" y="${wheel_y_offset}" roller_sign="-1"/>
  <xacro:mecanum_wheel prefix="rear_right" x="${-wheel_x_offset}" y="${-wheel_y_offset}" roller_sign="1"/>

  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="lidar_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${lidar_mass}"/>
      <inertia
        ixx="${lidar_mass * (3.0 * lidar_radius * lidar_radius + lidar_height * lidar_height) / 12.0}" ixy="0" ixz="0"
        iyy="${lidar_mass * (3.0 * lidar_radius * lidar_radius + lidar_height * lidar_height) / 12.0}" iyz="0"
        izz="${0.5 * lidar_mass * lidar_radius * lidar_radius}"/>
    </inertial>
  </link>

  <joint name="base_link_to_laser_frame" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="laser_frame">
    <sensor name="ydlidar_x4_pro" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>/scan</topic>
      <gz_frame_id>laser_frame</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>${-pi}</min_angle>
            <max_angle>${pi}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-mecanum-drive-system" name="gz::sim::systems::MecanumDrive">
      <front_left_joint>front_left_wheel_joint</front_left_joint>
      <front_right_joint>front_right_wheel_joint</front_right_joint>
      <back_left_joint>rear_left_wheel_joint</back_left_joint>
      <back_right_joint>rear_right_wheel_joint</back_right_joint>
      <wheel_separation>${wheel_y_offset * 2.0}</wheel_separation>
      <wheelbase>${wheel_x_offset * 2.0}</wheelbase>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
</robot>
