          <far>20.0</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="front_camera_controller">
        <ros>
          <namespace>/</namespace>
          <remapping>image_raw:=camera/image_raw</remapping>
