    <plugin filename="libgazebo_ros_diff_drive.so" name="four_wheel_diff_drive">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
